NODE_ENV=development
PORT=8080

# Frontend origins allowed by CORS. Use comma-separated values for multiple dev ports.
CLIENT_URL=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3002
CLIENT_REDIRECT_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/CONCH
DB_NAME=CONCH

# Auth
JWT_SECRET=replace-with-a-long-random-secret

# GitHub OAuth
# In GitHub OAuth App settings, set Authorization callback URL to:
# http://localhost:8080/api/auth/github/callback
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
GITHUB_CALLBACK_URL=http://localhost:8080/api/auth/github/callback
GITHUB_OAUTH_SCOPES=read:user user:email

# Optional email support for employee account emails.
RESEND_API_KEY=your-resend-api-key
SENDER_EMAIL=hello@bhavyadhanwani.dev

# Builder AI and logo uploads
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-flash-latest
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Deployment platform domains
# Your app reserves <site>.bhavyadhanwani.dev from this wildcard. DNS must point
# *.bhavyadhanwani.dev to your deployed frontend/proxy before these URLs resolve.
PLATFORM_DOMAIN=*.bhavyadhanwani.dev
PUBLIC_DEPLOYMENT_TARGET=your-vercel-or-server-target.example.com
